      "description": "Primary image source."
    },
    "reduced-src": {
      "type": "string",
      "description": "Fallback source used when prefers-reduced-motion is enabled."
    },
    "alt": {
      "type": "string",
      "default": "",
      "description": "Accessible alternative text."
    }
  },
  "slots": [],
  "registry": {
    "files": [
      "animated-image.css",
      "animated-image.js"
    ],
    "componentDeps": [],
    "libDeps": [],
    "npmDeps": []
  },
  "route": {
    "path": "/components/data-display/animated-image",
    "label": "AnimatedImage",
    "group": "data-display",
    "subgroup": "visualization-and-browsing",
    "description": "Image with reduced-motion fallback support"
  },
  "page": {
    "title": "Animated media with reduced-motion fallback",
    "code": "<sg-animated-image src=\"https://media.giphy.com/media/ICOgUNjpvO0PC/giphy.gif\" reduced-src=\"https://picsum.photos/640/360\" alt=\"Animated sample\"></sg-animated-image>"
  }
