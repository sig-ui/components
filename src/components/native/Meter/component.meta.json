{
  "name": "Meter",
  "importPath": "sg/meter",
  "category": "form",
  "description": "CSS-only styled native <meter>. Apply class=\"sg-meter\" on a <meter> element.",
  "whenToUse": "To display a scalar measurement within a known range (e.g. disk usage, battery level). Use class=\"sg-meter\".",
  "avoidWhen": "For task completion or loading - use Progress instead.",
  "semanticRole": "meter",
  "accessibilityRequirements": "Provide meaningful min/max/low/high/optimum values and a label.",
  "props": {
    "class": {
      "type": "string",
      "required": true,
      "description": "Use class=\"sg-meter\" on the <meter> element."
    },
    "data-size": {
      "type": "string",
      "values": [
        "sm",
        "md",
        "lg"
      ],
      "default": "md",
      "description": "Visual height of the meter bar."
    }
  },
  "slots": [],
  "registry": {
    "files": [
      "meter.css"
    ],
    "componentDeps": [],
    "libDeps": [],
    "npmDeps": []
  },
  "route": {
    "path": "/components/native/meter",
    "label": "Meter",
    "group": "native",
    "description": "Scalar measurement within a known range"
  },
  "page": {
    "sections": [
      {
        "title": "Examples",
        "examples": [
          {
            "title": "Optimum Range",
            "language": "svelte",
            "code": "<sg-stack gap=\"grouped\">\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Disk usage (optimum)</span>\n    <meter class=\"sg-meter\" value=\"0.7\" min=\"0\" max=\"1\" low=\"0.3\" high=\"0.7\" optimum=\"0.8\"></meter>\n  </div>\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Disk usage (suboptimum)</span>\n    <meter class=\"sg-meter\" value=\"0.85\" min=\"0\" max=\"1\" low=\"0.3\" high=\"0.7\" optimum=\"0.5\"></meter>\n  </div>\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Disk usage (critical)</span>\n    <meter class=\"sg-meter\" value=\"0.95\" min=\"0\" max=\"1\" low=\"0.3\" high=\"0.7\" optimum=\"0.2\"></meter>\n  </div>\n</sg-stack>"
          },
          {
            "title": "Sizes",
            "language": "svelte",
            "code": "<sg-stack gap=\"grouped\">\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Small</span>\n    <meter class=\"sg-meter\" data-size=\"sm\" value=\"0.6\" min=\"0\" max=\"1\"></meter>\n  </div>\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Medium (default)</span>\n    <meter class=\"sg-meter\" data-size=\"md\" value=\"0.6\" min=\"0\" max=\"1\"></meter>\n  </div>\n  <div class=\"sg-meter-wrapper\">\n    <span class=\"sg-meter-label\">Large</span>\n    <meter class=\"sg-meter\" data-size=\"lg\" value=\"0.6\" min=\"0\" max=\"1\"></meter>\n  </div>\n</sg-stack>"
          },
          {
            "title": "With Description",
            "language": "svelte",
            "code": "<div class=\"sg-meter-wrapper sg-demo-meter-1\">\n  <span class=\"sg-meter-label\">Battery</span>\n  <meter class=\"sg-meter\" value=\"0.35\" min=\"0\" max=\"1\" low=\"0.2\" high=\"0.8\" optimum=\"0.9\"></meter>\n  <span class=\"sg-meter-description\">35% remaining</span>\n</div>",
            "css": ".sg-demo-meter-1 {\n  max-width: 300px;\n}"
          }
        ]
      }
    ]
  }
}
